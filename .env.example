# .env.example — Reproducibility_Astro Configuration
# Copy to .env and fill in your values, then: source .env

# ── NASA ADS API (required for data collection) ───────────────────────────────
# Get a free token at: https://ui.adsabs.harvard.edu
# → sign in → Account → Settings → API Token
# ADS_API_TOKEN=your_token_here

# ── GitHub API (optional, for future enrichment step) ─────────────────────────
# Generate at: https://github.com/settings/tokens
# JUP_GITHUB_PASSWORD=your_github_token_here

# Path to pyenv installation (default: ~/.pyenv)
# PYENV_ROOT=~/.pyenv

# Directory where per-repo virtual environments are stored (default: ~/.repo_venvs)
# VENV_BASE_DIR=~/.repo_venvs

# Override the SQLite database path (default: data/output/db/db.sqlite)
# DB_FILE=/path/to/custom.sqlite

# Number of repos to process per batch run (default: 10)
# TARGET_COUNT=10
